<Layouts.app
  flash={@flash}
  notebook={@notebook}
  projects={@projects}
  project_name_form={@project_name_form}
  llm_status={@llm_status}
>
  <div class="w-full max-w-none px-2 pb-0 pt-3 sm:px-3 lg:px-3">
    <section
      id="notebook-shell"
      class="grid gap-3 lg:h-[calc(100vh-5rem)] lg:min-h-0 lg:grid-cols-[27.2rem_minmax(0,1fr)_26.4rem] lg:overflow-hidden"
    >
      <aside id="source-panel" class="min-h-0">
        <div class="flex h-full min-h-0 flex-col rounded-lg border border-zinc-200 bg-white shadow-sm">
          <div class="flex items-center gap-3 px-5 pb-1 pt-4">
            <.icon name="hero-archive-box" class="size-5 text-zinc-700" />
            <h2 class="text-base font-semibold text-zinc-950">Sources</h2>
            <div class="ml-auto flex items-center gap-2">
              <div class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-200 px-3">
                <span class="text-xs text-zinc-500">Sources</span>
                <span class="text-sm font-semibold text-zinc-950">{@source_count}</span>
              </div>
              <div class="inline-flex h-8 items-center gap-2 rounded-md border border-zinc-200 px-3">
                <span class="text-xs text-zinc-500">Words</span>
                <span class="text-sm font-semibold text-zinc-950">{@word_count}</span>
              </div>
            </div>
          </div>

          <div
            :if={@active_source}
            id="source-detail-view"
            class="flex min-h-0 flex-1 flex-col px-4 pb-4"
          >
            <div class="flex shrink-0 items-center gap-2 pb-3">
              <button
                id="close-source-detail-button"
                type="button"
                phx-click="close_source"
                class="inline-flex size-8 items-center justify-center rounded-md bg-zinc-100 text-zinc-700 transition hover:bg-zinc-200 hover:text-zinc-950"
                aria-label="Close source"
              >
                <.icon name="hero-arrow-left" class="size-4" />
              </button>
              <div class="min-w-0 flex-1">
                <h3
                  id="source-detail-title"
                  class="break-words text-sm font-semibold leading-5 text-zinc-950"
                >
                  {@active_source.title}
                </h3>
                <p class="text-xs text-zinc-500">{@active_source.word_count} words</p>
              </div>
            </div>
            <div
              id="source-detail-body"
              class="source-detail-body min-h-0 flex-1 overflow-y-auto rounded-md bg-zinc-50 px-3"
            >
              <p class="whitespace-pre-wrap text-sm leading-6">{@active_source.body}</p>
            </div>
          </div>

          <div :if={!@active_source} class="shrink-0 space-y-4 px-4 pb-3 pt-1">
            <div class="soft-control-panel rounded-md border border-zinc-200 bg-zinc-50">
              <button
                id="toggle-source-form-button"
                type="button"
                phx-click="toggle_source_form"
                aria-expanded={@show_source_form}
                class="flex h-8 w-full cursor-pointer items-center justify-between px-3 text-xs font-semibold text-zinc-700 transition hover:bg-zinc-100"
              >
                <span class="inline-flex items-center gap-2">
                  <.icon name="hero-plus" class="size-4" /> Add source
                </span>
                <.icon
                  name={if(@show_source_form, do: "hero-chevron-up", else: "hero-chevron-down")}
                  class="size-4 text-zinc-500"
                />
              </button>

              <.form
                for={@source_form}
                id="source-form"
                phx-submit="add_source"
                class={[
                  "space-y-2 px-3 pb-3",
                  !@show_source_form && "hidden"
                ]}
              >
                <.input
                  field={@source_form[:title]}
                  type="text"
                  label="Title"
                  placeholder="Quarterly research notes"
                  class="w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm text-zinc-950 outline-none transition focus:border-zinc-950 focus:ring-2 focus:ring-zinc-200"
                />
                <.input
                  field={@source_form[:body]}
                  type="textarea"
                  label="Source text"
                  placeholder="Paste documents, meeting notes, transcripts, or article excerpts."
                  rows="7"
                  class="min-h-36 w-full rounded-md border border-zinc-300 bg-white px-3 py-2 text-sm leading-6 text-zinc-950 outline-none transition focus:border-zinc-950 focus:ring-2 focus:ring-zinc-200"
                />
                <button
                  id="add-source-button"
                  type="submit"
                  class="inline-flex h-9 w-full items-center justify-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-semibold text-white transition hover:bg-zinc-800 phx-submit-loading:opacity-70"
                >
                  <.icon name="hero-document-plus" class="size-4" /> Add to notebook
                </button>
              </.form>
            </div>

            <div class="soft-control-panel rounded-lg border border-zinc-200 bg-zinc-50 p-2">
              <.form
                for={@web_search_form}
                id="web-search-form"
                phx-submit="web_search"
                class="flex items-center gap-2"
              >
                <div class="min-w-0 flex-1">
                  <input
                    type="search"
                    id={@web_search_form[:query].id}
                    name={@web_search_form[:query].name}
                    value={@web_search_form[:query].value}
                    placeholder="Search the web for new sources"
                    class="h-8 w-full rounded-md border border-transparent bg-transparent px-2 text-sm text-zinc-950 outline-none transition placeholder:text-zinc-500 focus:border-zinc-950 focus:bg-white focus:ring-2 focus:ring-zinc-200"
                  />
                </div>
                <button
                  id="web-search-button"
                  type="submit"
                  disabled={@web_searching}
                  class="web-search-action inline-flex size-8 shrink-0 items-center justify-center rounded-full bg-zinc-200 text-zinc-500 phx-submit-loading:opacity-70"
                  aria-label="Search web"
                >
                  <.icon :if={!@web_searching} name="hero-magnifying-glass" class="size-4" />
                  <.icon
                    :if={@web_searching}
                    name="hero-arrow-path"
                    class="size-4 motion-safe:animate-spin"
                  />
                </button>
              </.form>

              <.form
                :if={@web_results != []}
                for={@web_import_form}
                id="web-import-form"
                phx-submit="add_web_sources"
                class="mt-2 flex min-h-0 flex-col space-y-2 border-t border-zinc-200 pt-2"
              >
                <div class="grid h-8 grid-cols-[minmax(0,1fr)_4.75rem_1.25rem_1.25rem] items-center gap-1 pr-1">
                  <div class="min-w-0">
                    <button
                      id="add-web-sources-button"
                      type="submit"
                      disabled={MapSet.size(@importing_web_result_ids) > 0}
                      class="inline-flex h-8 shrink-0 items-center justify-center gap-1 rounded-md bg-zinc-950 px-3 py-1 text-sm font-semibold text-white transition hover:bg-zinc-800 phx-submit-loading:opacity-70"
                    >
                      <.icon
                        :if={MapSet.size(@importing_web_result_ids) == 0}
                        name="hero-plus"
                        class="size-4 phx-submit-loading:hidden"
                      />
                      <.icon
                        :if={MapSet.size(@importing_web_result_ids) > 0}
                        name="hero-arrow-path"
                        class="size-4 motion-safe:animate-spin"
                      />
                      <span class="whitespace-nowrap">
                        {if MapSet.size(@importing_web_result_ids) > 0,
                          do: "Adding...",
                          else: "Add selected"}
                      </span>
                    </button>
                  </div>
                  <span class="text-right text-sm font-medium text-zinc-950">Select all</span>
                  <input
                    id="web-result-select-all"
                    type="checkbox"
                    checked={all_web_results_selected?(@web_results, @web_import_form)}
                    phx-click="set_all_web_results"
                    phx-value-checked={
                      if all_web_results_selected?(@web_results, @web_import_form),
                        do: "false",
                        else: "true"
                    }
                    class="size-5 translate-x-[3px] shrink-0 cursor-pointer rounded border-zinc-300 text-zinc-950 accent-zinc-950 transition hover:border-zinc-500 hover:ring-2 hover:ring-zinc-200 focus:ring-zinc-400"
                  />
                  <button
                    id="cancel-web-results-button"
                    type="button"
                    phx-click="cancel_web_results"
                    class="inline-flex size-6 translate-x-1 shrink-0 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 hover:text-zinc-950"
                    aria-label="Close web results"
                  >
                    <.icon name="hero-x-mark" class="size-3.5" />
                  </button>
                </div>

                <div
                  id="web-results"
                  class="max-h-[29.75rem] min-h-0 flex-none space-y-1 overflow-y-auto pr-1"
                >
                  <label
                    :for={result <- @web_results}
                    id={"web-result-#{result.id}"}
                    class="flex min-h-14 items-center gap-3 rounded-lg px-2 py-2 transition hover:bg-zinc-100"
                  >
                    <img
                      src={favicon_src(result.url)}
                      alt=""
                      class="size-7 shrink-0 rounded-md"
                    />
                    <div class="min-w-0 flex-1">
                      <p class="truncate text-sm leading-5 text-zinc-950">{result.title}</p>
                      <p class="truncate text-xs text-zinc-500">{result.url}</p>
                    </div>
                    <input
                      :if={!MapSet.member?(@importing_web_result_ids, result.id)}
                      id={"web-result-checkbox-#{result.id}"}
                      type="checkbox"
                      name="web_import[result_ids][]"
                      value={result.id}
                      phx-click="toggle_web_import_result"
                      phx-value-result-id={result.id}
                      checked={web_result_checked?(@web_import_form, result)}
                      class="size-5 shrink-0 cursor-pointer rounded border-zinc-300 text-zinc-950 accent-zinc-950 transition hover:border-zinc-500 hover:ring-2 hover:ring-zinc-200 focus:ring-zinc-400"
                    />
                    <.icon
                      :if={MapSet.member?(@importing_web_result_ids, result.id)}
                      name="hero-arrow-path"
                      class="size-5 shrink-0 text-zinc-500 motion-safe:animate-spin"
                    />
                  </label>
                </div>
              </.form>
            </div>
          </div>

          <div
            :if={!@active_source}
            class="flex min-h-0 flex-1 flex-col gap-4 overflow-hidden px-4 pb-4"
          >
            <div class="grid h-8 shrink-0 grid-cols-[minmax(0,1fr)_4.75rem_1rem] items-center gap-2 pl-2 pr-6.5">
              <button
                id="delete-selected-sources-button"
                type="button"
                phx-click="delete_selected_sources"
                data-confirm="Delete selected sources?"
                class="destructive-action inline-flex w-fit items-center gap-1 rounded-md px-2 py-1 text-xs font-semibold text-zinc-600"
              >
                <.icon name="hero-trash" class="size-4" /> Delete selected
              </button>
              <span class="text-right text-xs font-medium text-zinc-950">Select all</span>
              <input
                id="source-refs-select-all"
                type="checkbox"
                checked={all_source_refs_selected?(@sources, @selected_source_ids)}
                phx-click="set_all_source_refs"
                phx-value-checked={
                  if(all_source_refs_selected?(@sources, @selected_source_ids),
                    do: "false",
                    else: "true"
                  )
                }
                class="size-4 cursor-pointer rounded border-zinc-300 text-zinc-950 accent-zinc-950 transition hover:border-zinc-500 hover:ring-2 hover:ring-zinc-200 focus:ring-zinc-400"
              />
            </div>

            <.form
              for={to_form(%{}, as: :source_refs)}
              id="source-refs-form"
              phx-change="source_refs_changed"
              class="flex min-h-0 flex-1 flex-col"
            >
              <div id="sources-list" class="min-h-0 flex-1 space-y-1 overflow-y-auto pr-1">
                <div
                  :if={@sources == []}
                  class="rounded-md bg-zinc-50 p-4 text-sm text-zinc-500"
                >
                  No sources yet.
                </div>
                <article
                  :for={source <- @sources}
                  id={"source-#{source.id}"}
                  class="grid h-9 grid-cols-[1.75rem_minmax(0,1fr)_1.75rem_1rem] items-center gap-2 rounded-md bg-zinc-50 px-2 transition hover:bg-zinc-100"
                >
                  <%= if source_favicon_src(source) do %>
                    <img
                      src={source_favicon_src(source)}
                      alt=""
                      class="size-7 shrink-0 rounded-md"
                    />
                  <% else %>
                    <span class="inline-flex size-7 shrink-0 items-center justify-center rounded-md border border-zinc-200 bg-zinc-100 text-xs font-bold text-zinc-700">
                      {String.first(source.title || "S")}
                    </span>
                  <% end %>
                  <button
                    id={"open-source-#{source.id}"}
                    type="button"
                    phx-click="open_source"
                    phx-value-id={source.id}
                    class="min-w-0 flex-1 overflow-hidden text-ellipsis whitespace-nowrap rounded-md text-left text-sm font-semibold text-zinc-950 transition hover:text-zinc-700"
                  >
                    {source.title}
                  </button>
                  <button
                    id={"delete-source-#{source.id}"}
                    type="button"
                    phx-click="delete_source"
                    phx-value-id={source.id}
                    class="destructive-action inline-flex size-7 items-center justify-center rounded-md text-zinc-500"
                    aria-label="Delete source"
                  >
                    <.icon name="hero-trash" class="size-4" />
                  </button>
                  <input
                    id={"source-ref-checkbox-#{source.id}"}
                    type="checkbox"
                    name="source_refs[source_ids][]"
                    value={source.id}
                    checked={source_ref_checked?(@selected_source_ids, source)}
                    class="size-4 shrink-0 cursor-pointer rounded border-zinc-300 text-zinc-950 accent-zinc-950 transition hover:border-zinc-500 hover:ring-2 hover:ring-zinc-200 focus:ring-zinc-400"
                  />
                </article>
              </div>
            </.form>
          </div>
        </div>
      </aside>

      <main
        id="chat-panel"
        class="flex min-h-0 flex-col rounded-lg border border-zinc-200 bg-white shadow-sm"
      >
        <div class="border-b border-zinc-200 px-5 pb-1 pt-4">
          <div class="flex flex-wrap items-center justify-between gap-3">
            <div class="flex items-center gap-2">
              <.icon name="hero-chat-bubble-left-right" class="size-5 text-zinc-700" />
              <h2 class="text-base font-semibold text-zinc-950">Chat & MCP result</h2>
            </div>
            <div class="flex items-center gap-2">
              <div class="inline-flex rounded-md border border-zinc-200 bg-zinc-50 p-0.5 text-xs font-semibold">
                <button
                  id="chat-mode-local"
                  type="button"
                  phx-click="set_chat_mode"
                  phx-value-mode="local"
                  class={[
                    "inline-flex h-7 items-center gap-1 rounded px-2 transition",
                    @chat_mode == "local" && "bg-[#167a43] text-white shadow-sm",
                    @chat_mode != "local" && "text-zinc-500 hover:bg-zinc-100"
                  ]}
                >
                  <.icon name="hero-check-circle" class="size-4" /> local ONLY
                </button>
                <button
                  id="chat-mode-local-web"
                  type="button"
                  phx-click="set_chat_mode"
                  phx-value-mode="local_web"
                  class={[
                    "inline-flex h-7 items-center gap-1 rounded px-2 transition",
                    @chat_mode == "local_web" && "bg-[#108696] text-white shadow-sm",
                    @chat_mode != "local_web" &&
                      "text-zinc-500 hover:bg-zinc-100"
                  ]}
                >
                  <.icon name="hero-magnifying-glass" class="size-4" /> local＋web
                </button>
                <button
                  id="chat-mode-web"
                  type="button"
                  phx-click="set_chat_mode"
                  phx-value-mode="web"
                  class={[
                    "inline-flex h-7 items-center gap-1 rounded px-2 transition",
                    @chat_mode == "web" && "bg-[#0a93e8] text-white shadow-sm",
                    @chat_mode != "web" && "text-zinc-500 hover:bg-zinc-100"
                  ]}
                >
                  <.icon name="hero-globe-alt" class="size-4" /> web ONLY
                </button>
              </div>
              <div class="flex items-center gap-2">
                <button
                  id="archive-chat-history-button"
                  type="button"
                  phx-click="archive_chat_history"
                  disabled={@chat_message_count == 0}
                  class="archive-action inline-flex h-8 w-8 items-center justify-center rounded-md border border-zinc-200 text-zinc-500 disabled:cursor-not-allowed disabled:opacity-40"
                  title="Archive chat history"
                >
                  <.icon name="hero-archive-box" class="size-4" />
                </button>
                <button
                  id="delete-chat-history-button"
                  type="button"
                  phx-click="delete_chat_history"
                  data-confirm="Delete chat history?"
                  disabled={@chat_message_count == 0}
                  class="destructive-action inline-flex h-8 w-8 items-center justify-center rounded-md border border-zinc-200 text-zinc-500 disabled:cursor-not-allowed disabled:opacity-40"
                  title="Delete chat history"
                >
                  <.icon name="hero-trash" class="size-4" />
                </button>
              </div>
            </div>
          </div>
        </div>

        <div
          id="messages"
          phx-hook="ChatScroll"
          phx-update="stream"
          class="min-h-0 flex-1 space-y-3 overflow-y-auto p-5"
        >
          <div
            id="messages-empty"
            class="hidden only:block rounded-lg border border-dashed border-zinc-300 p-8 text-center"
          >
            <.icon name="hero-sparkles" class="mx-auto size-8 text-zinc-400" />
            <p class="mt-3 text-sm font-medium text-zinc-950">No questions yet</p>
            <p class="mt-1 text-sm text-zinc-500">
              Add a source, then ask for a cited draft answer.
            </p>
          </div>
          <article
            :for={{id, message} <- @streams.messages}
            id={id}
            class={[
              "max-w-[89%] rounded-lg border p-4 shadow-sm",
              message_alignment(message.role),
              message_tone(message.role)
            ]}
          >
            <p class="whitespace-pre-wrap text-sm leading-6">{message.content}</p>
            <div :if={message.citations != %{}} class="mt-3 flex flex-wrap gap-2">
              <button
                :for={{index, citation} <- ordered_citations(message)}
                :if={citation["source_id"]}
                type="button"
                phx-click="open_citation_source"
                phx-value-source-id={citation["source_id"]}
                phx-value-position={citation["position"]}
                class="citation-local inline-flex items-center gap-1 rounded-full border border-[#6fbd98] bg-[#ebf8f1] px-2 py-1 text-xs text-[#0d5a3b] transition hover:border-[#2f9363] hover:bg-[#dff3e9]"
              >
                <.icon name="hero-document-text" class="size-3.5" />
                <span class="font-semibold">local</span>
                <span>[{index}] {citation["source_title"]}</span>
              </button>
              <button
                :for={{index, citation} <- ordered_citations(message)}
                :if={!citation["source_id"] && citation["source_url"]}
                type="button"
                phx-click="add_web_citation_source"
                phx-value-url={citation["source_url"]}
                data-confirm="Add this web source to Sources?"
                class="citation-web inline-flex items-center gap-1 rounded-full border border-[#78c7ee] bg-[#edf8fe] px-2 py-1 text-xs text-[#126999] transition hover:border-[#35a7e3] hover:bg-[#d9f0fc]"
              >
                <.icon name="hero-globe-alt" class="size-3.5" />
                <span class="font-semibold">web</span>
                <span>[{index}] {citation["source_title"]}</span>
              </button>
            </div>
          </article>
        </div>

        <div class="border-t border-zinc-200 p-4">
          <.form
            for={@question_form}
            id="question-form"
            phx-change="question_changed"
            phx-submit="ask"
            class="flex w-full items-center gap-2"
          >
            <div class="min-w-0 flex-1">
              <input
                type="text"
                id={@question_form[:question].id}
                name={@question_form[:question].name}
                value={@question_form[:question].value}
                placeholder="What do the sources say about pricing risk?"
                class="h-11 w-full min-w-0 rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-950 outline-none transition focus:border-zinc-950 focus:ring-2 focus:ring-zinc-200"
              />
            </div>
            <button
              id="ask-button"
              type="submit"
              disabled={@asking || ask_disabled?(@chat_mode, @selected_source_ids)}
              class={[
                "inline-flex h-11 shrink-0 items-center justify-center gap-2 rounded-md px-4 text-sm font-semibold text-white transition phx-submit-loading:opacity-70 sm:min-w-24",
                (@asking || ask_disabled?(@chat_mode, @selected_source_ids)) &&
                  "cursor-not-allowed bg-zinc-400",
                !@asking && !ask_disabled?(@chat_mode, @selected_source_ids) &&
                  "bg-zinc-950 hover:bg-zinc-800"
              ]}
            >
              <.icon :if={!@asking} name="hero-paper-airplane" class="size-4" />
              <.icon
                :if={@asking}
                name="hero-arrow-path"
                class="size-4 motion-safe:animate-spin"
              />
              <span>{if @asking, do: "Asking...", else: "Ask"}</span>
            </button>
          </.form>
        </div>
      </main>

      <aside id="mcp-panel" class="flex h-full min-h-0 flex-col gap-4 overflow-hidden">
        <div class="order-2 shrink-0 rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
          <div class="flex items-center gap-2">
            <.icon name="hero-server-stack" class="size-5 text-zinc-700" />
            <h2 class="text-base font-semibold text-zinc-950">Embedded MCP</h2>
          </div>
          <div class="mt-4 rounded-md bg-zinc-100 px-2 py-1 font-mono text-xs text-zinc-800">
            POST /mcp
          </div>
          <.form
            for={@mcp_form}
            id="mcp-execute-form"
            phx-submit="execute_mcp"
            class="mt-4 space-y-2"
          >
            <div class="grid grid-cols-2 gap-2">
              <label class="text-xs font-medium text-zinc-600">
                Mode
                <select
                  name="mcp[operation]"
                  class="mt-1 h-8 w-full rounded-md border border-zinc-300 bg-white px-2 text-xs text-zinc-950"
                >
                  <option value="tool" selected={@mcp_form[:operation].value == "tool"}>
                    tool
                  </option>
                  <option
                    value="resource_list"
                    selected={@mcp_form[:operation].value == "resource_list"}
                  >
                    resources/list
                  </option>
                  <option
                    value="resource_read"
                    selected={@mcp_form[:operation].value == "resource_read"}
                  >
                    resources/read
                  </option>
                </select>
              </label>
              <label class="text-xs font-medium text-zinc-600">
                Tool
                <select
                  name="mcp[tool]"
                  class="mt-1 h-8 w-full rounded-md border border-zinc-300 bg-white px-2 text-xs text-zinc-950"
                >
                  <option value="notex.search" selected={@mcp_form[:tool].value == "notex.search"}>
                    search
                  </option>
                  <option value="notex.answer" selected={@mcp_form[:tool].value == "notex.answer"}>
                    answer
                  </option>
                  <option
                    value="notex.list_notebooks"
                    selected={@mcp_form[:tool].value == "notex.list_notebooks"}
                  >
                    list_notebooks
                  </option>
                  <option
                    value="notex.llm_status"
                    selected={@mcp_form[:tool].value == "notex.llm_status"}
                  >
                    llm_status
                  </option>
                  <option
                    value="notex.add_source"
                    selected={@mcp_form[:tool].value == "notex.add_source"}
                  >
                    add_source
                  </option>
                </select>
              </label>
            </div>
            <input
              type="text"
              name="mcp[query]"
              value={@mcp_form[:query].value}
              placeholder="Query or question"
              class="h-9 w-full rounded-md border border-zinc-300 bg-white px-3 text-sm text-zinc-950 outline-none focus:border-zinc-950 focus:ring-2 focus:ring-zinc-200"
            />
            <details class="soft-control-panel rounded-md border border-zinc-200 bg-zinc-50">
              <summary class="flex h-8 cursor-pointer items-center gap-2 px-3 text-xs font-semibold text-zinc-700 transition hover:bg-zinc-100">
                <.icon name="hero-adjustments-horizontal" class="size-4" /> Advanced
              </summary>
              <div class="px-3 pb-2">
                <div class="fieldset mb-2">
                  <label>
                    <span class="label mb-1">Resource URI</span>
                    <input
                      type="text"
                      name="mcp[resource_uri]"
                      value={@mcp_form[:resource_uri].value}
                      placeholder="notex:// resource URI"
                      class="h-9 w-full rounded-md border border-zinc-300 bg-white px-3 font-mono text-xs text-zinc-950 outline-none focus:border-zinc-950 focus:ring-2 focus:ring-zinc-200"
                    />
                  </label>
                </div>
                <div class="fieldset">
                  <label>
                    <span class="label mb-1">Arguments</span>
                    <textarea
                      name="mcp[arguments]"
                      rows="3"
                      class="w-full rounded-md border border-zinc-300 bg-white px-3 py-2 font-mono text-xs text-zinc-950 outline-none focus:border-zinc-950 focus:ring-2 focus:ring-zinc-200"
                    >{@mcp_form[:arguments].value}</textarea>
                  </label>
                </div>
              </div>
            </details>
            <button
              id="mcp-execute-button"
              type="submit"
              disabled={@mcp_running}
              class="inline-flex h-9 w-full items-center justify-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-semibold text-white transition hover:bg-zinc-800 phx-submit-loading:opacity-70"
            >
              <.icon
                :if={!@mcp_running}
                name="hero-play"
                class="size-4 phx-submit-loading:hidden"
              />
              <.icon
                :if={@mcp_running}
                name="hero-arrow-path"
                class="size-4 motion-safe:animate-spin"
              />
              <span>{if @mcp_running, do: "Running...", else: "Run MCP"}</span>
            </button>
          </.form>
        </div>

        <div class="order-1 flex min-h-0 flex-1 flex-col rounded-lg border border-zinc-200 bg-white p-4 shadow-sm">
          <div class="flex items-center gap-2">
            <.icon name="hero-rectangle-group" class="size-5 text-zinc-700" />
            <h2 class="text-base font-semibold text-zinc-950">Media</h2>
            <div class="ml-auto inline-flex h-8 items-center gap-2 rounded-md border border-zinc-200 px-3">
              <span class="text-xs text-zinc-500">Generated</span>
              <span class="text-sm font-semibold text-zinc-950">{length(@studio_outputs)}</span>
            </div>
          </div>

          <div class="mt-4 grid shrink-0 grid-cols-2 gap-2 sm:grid-cols-3">
            <div
              :for={action <- studio_actions()}
              class={[
                "studio-media-action flex h-10 min-w-0 items-center overflow-hidden rounded-lg text-[11px] font-semibold transition",
                action.bg,
                action.text
              ]}
            >
              <button
                id={action.id}
                type="button"
                phx-click="generate_studio"
                phx-value-artifact={action.artifact}
                class={[
                  "flex h-full min-w-0 flex-1 items-center gap-1 px-1.5 text-left transition phx-click-loading:opacity-70 phx-click-loading:ring-2",
                  action.hover,
                  action.ring
                ]}
              >
                <.icon name={action.icon} class="size-4 shrink-0" />
                <span class="truncate">{action.label}</span>
              </button>
              <button
                id={action.settings_id}
                type="button"
                phx-click="open_studio_settings"
                phx-value-artifact={action.artifact}
                class="studio-settings-button mr-1 inline-flex size-7 shrink-0 items-center justify-center rounded-full bg-white/75 transition hover:bg-white hover:ring-2 hover:ring-white/70"
                aria-label={"Open #{action.label} generation settings"}
              >
                <.icon
                  :if={studio_generating?(@generating_studio_artifacts, action.artifact)}
                  name="hero-arrow-path"
                  class="size-4 animate-spin"
                />
                <.icon
                  :if={!studio_generating?(@generating_studio_artifacts, action.artifact)}
                  name="hero-chevron-right"
                  class="size-3.5"
                />
              </button>
            </div>
          </div>

          <div class="mt-4 flex min-h-0 flex-1 flex-col rounded-lg p-3">
            <div class="flex items-center justify-between gap-2">
              <h3 class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">
                Generated
              </h3>
            </div>
            <div
              id="studio-output-list"
              class="mt-2 min-h-0 flex-1 space-y-1 overflow-y-auto pr-1"
            >
              <p :if={@studio_outputs == []} class="text-sm text-zinc-500">
                No Studio outputs yet.
              </p>
              <div
                :for={output <- @studio_outputs}
                id={"studio-output-#{output.id}"}
                class={[
                  "studio-media-tone flex h-10 w-full items-center justify-between gap-1 rounded-md border border-zinc-200 text-xs transition hover:ring-2 hover:ring-zinc-200",
                  @active_studio_output && @active_studio_output.id == output.id &&
                    "ring-2 ring-zinc-400",
                  output.tone
                ]}
              >
                <button
                  type="button"
                  phx-click="open_studio_output"
                  phx-value-id={output.id}
                  class="inline-flex h-full min-w-0 flex-1 items-center justify-between gap-2 rounded-md px-2 text-left transition hover:bg-white/50"
                >
                  <span class="inline-flex min-w-0 items-center gap-2">
                    <.icon name={output.icon} class="size-4 shrink-0" />
                    <span class="truncate font-semibold">{output.title}</span>
                  </span>
                  <span class="inline-flex shrink-0 items-center gap-1 text-zinc-500">
                    <span class="hidden sm:inline">{output.label}</span>
                  </span>
                </button>
                <button
                  id={"delete-studio-output-#{output.id}"}
                  type="button"
                  phx-click="delete_studio_output"
                  phx-value-id={output.id}
                  class="destructive-action inline-flex size-8 shrink-0 items-center justify-center rounded-md text-zinc-500"
                  aria-label="Delete Studio output"
                >
                  <.icon name="hero-trash" class="size-4" />
                </button>
              </div>
            </div>
          </div>
        </div>
      </aside>
    </section>

    <div
      :if={@active_studio_settings_artifact}
      id="studio-settings-modal"
      class="fixed inset-0 z-50 flex items-center justify-center bg-zinc-950/45 p-3 sm:p-6"
      phx-window-keydown="close_studio_settings"
      phx-key="escape"
    >
      <button
        id="studio-settings-modal-backdrop"
        type="button"
        phx-click="close_studio_settings"
        class="absolute inset-0 cursor-default"
        aria-label="Close Studio settings"
      >
      </button>
      <div class="relative w-full max-w-lg rounded-lg border border-zinc-200 bg-white shadow-2xl">
        <div class="flex items-start justify-between gap-4 border-b border-zinc-200 px-5 py-4">
          <div class="min-w-0">
            <p class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">
              Generation Settings
            </p>
            <h3 class="mt-1 flex items-center gap-2 text-lg font-semibold text-zinc-950">
              <.icon
                name={active_studio_settings(@active_studio_settings_artifact).icon}
                class="size-5 shrink-0"
              />
              {active_studio_settings(@active_studio_settings_artifact).label}
            </h3>
          </div>
          <button
            id="close-studio-settings-button"
            type="button"
            phx-click="close_studio_settings"
            class="inline-flex size-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 hover:text-zinc-950"
            aria-label="Close Studio settings"
          >
            <.icon name="hero-x-mark" class="size-4" />
          </button>
        </div>

        <div class="space-y-4 px-5 py-4">
          <div class="rounded-md bg-zinc-50 p-3">
            <div class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">
              Sources
            </div>
            <div class="mt-1 text-sm font-medium text-zinc-950">
              {length(@selected_source_ids)} selected
            </div>
          </div>
          <div class="rounded-md bg-zinc-50 p-3">
            <div class="text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">
              Output
            </div>
            <div class="mt-1 text-sm font-medium text-zinc-950">
              {active_studio_settings(@active_studio_settings_artifact).label}
            </div>
          </div>
        </div>

        <div class="flex justify-end gap-2 border-t border-zinc-200 px-5 py-4">
          <button
            type="button"
            phx-click="close_studio_settings"
            class="inline-flex h-9 items-center justify-center rounded-md border border-zinc-200 px-3 text-sm font-semibold text-zinc-700 transition hover:bg-zinc-50"
          >
            Cancel
          </button>
          <button
            id="studio-settings-generate-button"
            type="button"
            phx-click="generate_studio_from_settings"
            phx-value-artifact={@active_studio_settings_artifact}
            class="inline-flex h-9 items-center justify-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-semibold text-white transition hover:bg-zinc-800"
          >
            <.icon name="hero-sparkles" class="size-4" /> Generate
          </button>
        </div>
      </div>
    </div>

    <div
      :if={@active_studio_output}
      id="studio-output-modal"
      class="fixed inset-0 z-50 flex items-center justify-center bg-zinc-950/45 p-3 backdrop-blur-sm sm:p-6"
      phx-window-keydown="close_studio_output"
      phx-key="escape"
    >
      <button
        id="studio-output-modal-backdrop"
        type="button"
        phx-click="close_studio_output"
        class="absolute inset-0 cursor-default"
        aria-label="Close Studio output"
      >
      </button>
      <div
        id="studio-player"
        class="relative flex max-h-[88vh] w-full max-w-[96rem] flex-col rounded-lg border border-zinc-200 bg-white shadow-2xl"
      >
        <div class="flex shrink-0 items-start justify-between gap-4 border-b border-zinc-200 px-4 py-3 sm:px-5">
          <div class="min-w-0">
            <p class="inline-flex items-center gap-2 text-xs font-semibold uppercase tracking-[0.14em] text-zinc-500">
              <.icon name={@active_studio_output.icon} class="size-4 shrink-0" />
              {@active_studio_output.label}
            </p>
            <h3 class="mt-1 break-words text-base font-semibold leading-6 text-zinc-950">
              {@active_studio_output.title}
            </h3>
            <time class="mt-1 block text-xs text-zinc-500">
              {Calendar.strftime(@active_studio_output.inserted_at, "%Y-%m-%d %H:%M")}
            </time>
          </div>
          <div class="inline-flex shrink-0 items-center gap-1">
            <button
              id={"delete-active-studio-output-#{@active_studio_output.id}"}
              type="button"
              phx-click="delete_studio_output"
              phx-value-id={@active_studio_output.id}
              class="destructive-action inline-flex size-8 items-center justify-center rounded-md text-zinc-500"
              aria-label="Delete Studio output"
            >
              <.icon name="hero-trash" class="size-4" />
            </button>
            <button
              id="close-studio-output-button"
              type="button"
              phx-click="close_studio_output"
              class="inline-flex size-8 items-center justify-center rounded-md text-zinc-500 hover:bg-zinc-100 hover:text-zinc-950"
              aria-label="Close Studio output"
            >
              <.icon name="hero-x-mark" class="size-4" />
            </button>
          </div>
        </div>

        <div class="min-h-0 flex-1 overflow-y-auto px-4 py-4 sm:px-5">
          <button
            :if={@active_studio_output.type == "audio"}
            id={"play-studio-output-#{@active_studio_output.id}"}
            type="button"
            phx-hook="SpeechPlayer"
            data-text={@active_studio_output.content}
            class="mb-4 inline-flex h-10 w-full items-center justify-center gap-2 rounded-md bg-zinc-950 px-3 text-sm font-semibold text-white transition hover:bg-zinc-800"
          >
            <.icon name="hero-play" class="size-4" /> Play audio
          </button>

          <img
            :if={@active_studio_output.type == "image"}
            id={"studio-image-#{@active_studio_output.id}"}
            src={@active_studio_output.content}
            alt={@active_studio_output.title}
            class="mx-auto max-h-[68vh] w-auto max-w-full rounded-lg border border-zinc-200 bg-white object-contain shadow-sm"
          />

          <video
            :if={@active_studio_output.type == "video"}
            id={"studio-video-#{@active_studio_output.id}"}
            src={@active_studio_output.content}
            controls
            class="mx-auto max-h-[68vh] w-full max-w-5xl rounded-lg border border-zinc-200 bg-black shadow-sm"
          >
          </video>

          <div :if={@active_studio_output.type == "cards"} class="flashcard-stage">
            <% flashcards = studio_flashcards(@active_studio_output) %>
            <% flashcard = active_flashcard(@active_studio_output, @active_flashcard_index) %>
            <%= if flashcard do %>
              <button
                type="button"
                phx-click="show_flashcard_answer"
                class={[
                  "flashcard-face",
                  @active_flashcard_answer? && "is-answer"
                ]}
              >
                <div class="flashcard-count">
                  {@active_flashcard_index + 1}/{length(flashcards)}
                </div>
                <div class="flashcard-menu">⋮</div>
                {flashcard_text_html(
                  if(@active_flashcard_answer?, do: flashcard.back, else: flashcard.front)
                )}
                <div :if={!@active_flashcard_answer?} class="flashcard-hint">回答を表示</div>
              </button>
              <div class="flashcard-controls">
                <button
                  type="button"
                  phx-click="previous_flashcard"
                  class="flashcard-nav"
                  aria-label="Previous flashcard"
                >
                  ←
                </button>
                <button type="button" class="flashcard-score is-wrong" aria-label="Wrong">
                  × <span>0</span>
                </button>
                <button type="button" class="flashcard-score is-right" aria-label="Right">
                  <span>0</span> ✓
                </button>
                <button
                  type="button"
                  phx-click="next_flashcard"
                  class="flashcard-nav is-next"
                  aria-label="Next flashcard"
                >
                  →
                </button>
              </div>
            <% else %>
              <div id={"studio-markdown-#{@active_studio_output.id}"} class="studio-markdown">
                {markdown_html(@active_studio_output.content)}
              </div>
            <% end %>
          </div>

          <div
            :if={@active_studio_output.type == "slides"}
            id={"studio-slides-#{@active_studio_output.id}"}
            class="studio-slides is-infographic-slides"
          >
            <section
              :for={
                {slide, index} <-
                  Enum.with_index(studio_slides(@active_studio_output), 1)
              }
              class="studio-slide"
            >
              <img
                class="studio-slide-image"
                src={slide_image_src(slide, index)}
                alt={"Slide #{index}"}
              />
            </section>
          </div>

          <div
            :if={@active_studio_output.type not in ["cards", "image", "video", "slides"]}
            id={"studio-markdown-#{@active_studio_output.id}"}
            phx-hook="MermaidRenderer"
            phx-update="ignore"
            class="studio-markdown rounded-md bg-zinc-50 p-4 text-sm leading-6 text-zinc-800"
          >
            {markdown_html(@active_studio_output.content)}
          </div>
        </div>
      </div>
    </div>
  </div>
</Layouts.app>
